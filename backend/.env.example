# Google AI credentials
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash-001
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite-001

# Quota-friendly run mode: 1 = one model call per run (manual step mode)
AGENT_MAX_STEPS=1

# Google Cloud project (used for Cloud Run deployment)
GCP_PROJECT_ID=your-gcp-project-id
USE_VERTEX=true
VERTEX_LOCATION=us-central1

# Allowed frontend origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000,https://localhost:3000
